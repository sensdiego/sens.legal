---
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
import Search from '../components/Search.astro';

interface Props {
  title: string;
  description?: string;
  lang?: 'en' | 'pt-br';
}

const { title, description = 'Legal intelligence infrastructure', lang = 'en' } = Astro.props;
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<!doctype html>
<html lang={lang === 'pt-br' ? 'pt-BR' : 'en'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <title>{title} — sens.legal</title>
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="sens.legal" />
    <meta property="og:title" content={`${title} — sens.legal`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:image" content={new URL('/og-image.png', Astro.site).href} />
    <meta property="og:locale" content={lang === 'pt-br' ? 'pt_BR' : 'en_US'} />
    <meta property="og:locale:alternate" content={lang === 'pt-br' ? 'en_US' : 'pt_BR'} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} — sens.legal`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL('/og-image.png', Astro.site).href} />

    <!-- Canonical + hreflang -->
    <link rel="canonical" href={Astro.url.href} />
    {lang === 'pt-br' ? (
      <>
        <link rel="alternate" hreflang="pt-BR" href={Astro.url.href} />
        <link rel="alternate" hreflang="en" href={new URL(Astro.url.pathname.replace('/pt-br', '') || '/', Astro.site).href} />
      </>
    ) : (
      <>
        <link rel="alternate" hreflang="en" href={Astro.url.href} />
        <link rel="alternate" hreflang="pt-BR" href={new URL(`/pt-br${Astro.url.pathname}`, Astro.site).href} />
      </>
    )}
    <link rel="alternate" hreflang="x-default" href={new URL(lang === 'pt-br' ? Astro.url.pathname.replace('/pt-br', '') || '/' : Astro.url.pathname, Astro.site).href} />
  </head>
  <body>
    <Header lang={lang} />
    <Sidebar currentPath={currentPath} lang={lang} />
    <Search lang={lang} />

    <main class="content">
      <article class="content-inner">
        <slot />
      </article>
    </main>

    <Footer lang={lang} />

    <script>
      // Mobile sidebar toggle
      const toggle = document.getElementById('menu-toggle');
      const sidebar = document.getElementById('sidebar');

      toggle?.addEventListener('click', () => {
        sidebar?.classList.toggle('open');
      });

      // Close sidebar on link click (mobile)
      sidebar?.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => {
          sidebar?.classList.remove('open');
        });
      });
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/portal.css';
</style>

<style>
  .content {
    margin-left: var(--sidebar-width);
    min-height: calc(100vh - var(--header-height));
    padding: var(--space-3xl) var(--space-xl) var(--space-3xl);
  }

  .content-inner {
    max-width: var(--content-max-width);
    margin: 0 auto;
  }

  @media (max-width: 50rem) {
    .content {
      margin-left: 0;
      padding: var(--space-xl) var(--space-lg);
    }
  }
</style>
