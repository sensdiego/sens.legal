---
import DocsLayout from '../layouts/DocsLayout.astro';
import ProofPoints from '../components/ProofPoints.astro';
import { capabilities } from '../data/constants';
---

<DocsLayout title="Home" description="Traceable legal intelligence infrastructure for Brazilian law.">
  <img src="/logo-hero.png" alt="sens.legal" class="hero-logo" />
  <p class="tagline">Traceable legal intelligence infrastructure</p>

  <p class="intro">
    sens.legal builds and documents the infrastructure behind
    <strong>Silo</strong> — a legal knowledge graph that turns frontier LLMs
    into traceable, auditable legal consultants.
  </p>

  <h2 class="silo-name">Silo</h2>

  <ProofPoints lang="en" />

  <div class="waitlist-cta">
    <p>Join the waitlist for early access.</p>
    <form id="waitlist-form" class="waitlist-form">
      <input type="email" name="email" placeholder="you@example.com" required />
      <button type="submit">Join waitlist</button>
    </form>
    <p id="waitlist-msg" class="waitlist-msg" style="display:none;"></p>
  </div>

  <hr />

  <h2>What is Silo</h2>

  <p>
    Frontier models hallucinate citations, miss relationships between decisions,
    and offer no audit trail. Lawyers cannot trust AI answers without evidence.
  </p>

  <p>
    Silo is a 360-degree legal knowledge graph that materializes the legal syllogism
    into a navigable data structure. It empowers LLMs with structured, relational,
    and verifiable data about how Brazilian courts decide — so every answer is
    traceable back to real decisions.
  </p>

  <p>
    <a href="/silo">Learn more about Silo &rarr;</a>
  </p>

  <hr />

  <h2>Capabilities</h2>

  <ul class="capability-list">
    {capabilities.map((c) => (
      <li><a href={`/silo#${c.id}`}>{c.name}</a></li>
    ))}
  </ul>

  <hr />

  <h2>Architecture</h2>

  <p>
    Silo is built on PostgreSQL, Neo4j, Qdrant, and Redis — with a REST API
    and MCP server that let any LLM or agent query the graph. The system ingests
    tribunal decisions, extracts entities and relationships, and serves them
    through graph-led retrieval.
  </p>

  <p>
    <a href="/architecture">View full architecture diagrams &rarr;</a>
  </p>
</DocsLayout>

<style>
  .hero-logo {
    display: block;
    max-width: 16rem;
    height: auto;
    margin-bottom: var(--space-sm);
  }

  .tagline {
    color: var(--color-text-muted);
    font-size: 1.125rem;
    margin-bottom: var(--space-sm);
  }

  .intro {
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    margin-bottom: var(--space-xl);
  }

  hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-2xl) 0;
  }

  .capability-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm) var(--space-lg);
  }

  .capability-list li a {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
  }

  .capability-list li a:hover {
    color: var(--color-text);
  }

  .waitlist-cta {
    margin-bottom: var(--space-lg);
  }

  .waitlist-cta > p {
    color: var(--color-text-secondary);
    margin-bottom: var(--space-sm);
  }

  .waitlist-form {
    display: flex;
    gap: var(--space-sm);
    max-width: 28rem;
  }

  .waitlist-form input {
    flex: 1;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    font-size: 0.9rem;
    background: var(--color-bg);
    color: var(--color-text);
  }

  .waitlist-form button {
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    background: var(--color-text);
    color: var(--color-bg);
    font-size: 0.9rem;
    cursor: pointer;
    white-space: nowrap;
  }

  .waitlist-form button:hover {
    opacity: 0.9;
  }

  .waitlist-msg {
    font-size: 0.85rem;
    margin-top: var(--space-xs);
  }
</style>

<script>
  const form = document.getElementById('waitlist-form') as HTMLFormElement | null;
  const msg = document.getElementById('waitlist-msg') as HTMLElement | null;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('button') as HTMLButtonElement | null;
    if (!btn || !msg) return;
    btn.disabled = true;
    btn.textContent = '...';
    try {
      const input = form.querySelector('input[name="email"]') as HTMLInputElement | null;
      if (!input) return;
      const res = await fetch('/api/waitlist', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: input.value }),
      });
      const data = await res.json();
      if (data.ok) {
        msg.textContent = 'You\'re on the list!';
        msg.style.display = 'block';
        form.style.display = 'none';
      } else {
        msg.textContent = data.error || 'Something went wrong.';
        msg.style.display = 'block';
        btn.disabled = false;
        btn.textContent = 'Join waitlist';
      }
    } catch {
      msg.textContent = 'Something went wrong.';
      msg.style.display = 'block';
      btn.disabled = false;
      btn.textContent = 'Join waitlist';
    }
  });
</script>
