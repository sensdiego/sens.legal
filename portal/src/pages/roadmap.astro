---
import DocsLayout from '../layouts/DocsLayout.astro';
import MilestoneStatus from '../components/MilestoneStatus.astro';
import { milestones } from '../data/constants';
---

<DocsLayout title="Roadmap" description="Silo development roadmap and milestones.">
  <h1>Roadmap</h1>

  <p>
    Silo is in active development. The roadmap below shows the major milestones
    from foundation to pitch readiness.
  </p>

  <MilestoneStatus milestones={milestones} lang="en" />

  <hr />

  <h2>How to read this</h2>
  <p>
    This is an editorial snapshot, not a numeric certainty. Milestones reflect
    current priorities and may shift as we learn from validation.
  </p>
</DocsLayout>
