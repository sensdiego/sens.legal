---
import DocsLayout from '../layouts/DocsLayout.astro';
import ProjectRoadmapStatus from '../components/ProjectRoadmapStatus.astro';
import { ecosystemContent, projects } from '../data/projects';
---

<DocsLayout title="Roadmap" description="Product roadmap for the sens.legal ecosystem.">
  <h1>Roadmap</h1>

  <p>{ecosystemContent.roadmap.intro}</p>

  <p>{ecosystemContent.roadmap.readingRule}</p>

  {projects.map((project) => (
    <>
      <h2>{project.name}</h2>
      <ProjectRoadmapStatus project={project} />
    </>
  ))}

  <h2>Ecosystem</h2>

  <ul>
    {ecosystemContent.roadmap.principles.map((item) => (
      <li>{item}</li>
    ))}
  </ul>
</DocsLayout>
