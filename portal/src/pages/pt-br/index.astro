---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ProofPoints from '../../components/ProofPoints.astro';
import { capabilities } from '../../data/constants';
---

<DocsLayout title="Inicio" description="Infraestrutura de inteligencia juridica rastreavel para o direito brasileiro." lang="pt-br">
  <img src="/logo-hero.png" alt="sens.legal" class="hero-logo" />
  <p class="tagline">Infraestrutura de inteligencia juridica rastreavel</p>

  <p class="intro">
    sens.legal constroi e documenta a infraestrutura por tras do
    <strong>Silo</strong> — um grafo de conhecimento juridico que transforma
    LLMs de fronteira em consultores juridicos rastreaveis e auditaveis.
  </p>

  <h2 class="silo-name">Silo</h2>

  <ProofPoints lang="pt-br" />

  <div class="waitlist-cta">
    <p>Entre na lista de espera para acesso antecipado.</p>
    <form id="waitlist-form" class="waitlist-form">
      <input type="email" name="email" placeholder="voce@exemplo.com" required />
      <button type="submit">Entrar na lista</button>
    </form>
    <p id="waitlist-msg" class="waitlist-msg" style="display:none;"></p>
  </div>

  <hr />

  <h2>O que e o Silo</h2>

  <p>
    Modelos de fronteira alucinam citacoes, perdem relacoes entre decisoes
    e nao oferecem trilha de auditoria. Advogados nao podem confiar em
    respostas de IA sem evidencias.
  </p>

  <p>
    Silo e um grafo de conhecimento juridico 360 graus que materializa o
    silogismo juridico em uma estrutura de dados navegavel. Ele equipa LLMs
    com dados estruturados, relacionais e verificaveis sobre como tribunais
    brasileiros decidem — para que cada resposta seja rastreavel ate decisoes reais.
  </p>

  <p>
    <a href="/pt-br/silo">Saiba mais sobre o Silo &rarr;</a>
  </p>

  <hr />

  <h2>Capacidades</h2>

  <ul class="capability-list">
    {capabilities.map((c) => (
      <li><a href={`/pt-br/silo#${c.id}`}>{c.namePtBr}</a></li>
    ))}
  </ul>

  <hr />

  <h2>Arquitetura</h2>

  <p>
    Silo e construido sobre PostgreSQL, Neo4j, Qdrant e Redis — com uma API REST
    e servidor MCP que permitem a qualquer LLM ou agente consultar o grafo.
    O sistema ingere decisoes de tribunais, extrai entidades e relacoes, e as
    serve por meio de retrieval guiado por grafo.
  </p>

  <p>
    <a href="/pt-br/architecture">Ver diagramas completos de arquitetura &rarr;</a>
  </p>
</DocsLayout>

<style>
  .hero-logo {
    display: block;
    max-width: 16rem;
    height: auto;
    margin-bottom: var(--space-sm);
  }

  .tagline {
    color: var(--color-text-muted);
    font-size: 1.125rem;
    margin-bottom: var(--space-sm);
  }

  .intro {
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    margin-bottom: var(--space-xl);
  }

  hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-2xl) 0;
  }

  .capability-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm) var(--space-lg);
  }

  .capability-list li a {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
  }

  .capability-list li a:hover {
    color: var(--color-text);
  }

  .waitlist-cta {
    margin-bottom: var(--space-lg);
  }

  .waitlist-cta > p {
    color: var(--color-text-secondary);
    margin-bottom: var(--space-sm);
  }

  .waitlist-form {
    display: flex;
    gap: var(--space-sm);
    max-width: 28rem;
  }

  .waitlist-form input {
    flex: 1;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    font-size: 0.9rem;
    background: var(--color-bg);
    color: var(--color-text);
  }

  .waitlist-form button {
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    background: var(--color-text);
    color: var(--color-bg);
    font-size: 0.9rem;
    cursor: pointer;
    white-space: nowrap;
  }

  .waitlist-form button:hover {
    opacity: 0.9;
  }

  .waitlist-msg {
    font-size: 0.85rem;
    margin-top: var(--space-xs);
  }
</style>

<script>
  const form = document.getElementById('waitlist-form') as HTMLFormElement | null;
  const msg = document.getElementById('waitlist-msg') as HTMLElement | null;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('button') as HTMLButtonElement | null;
    if (!btn || !msg) return;
    btn.disabled = true;
    btn.textContent = '...';
    try {
      const input = form.querySelector('input[name="email"]') as HTMLInputElement | null;
      if (!input) return;
      const res = await fetch('/api/waitlist', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: input.value }),
      });
      const data = await res.json();
      if (data.ok) {
        msg.textContent = 'Voce esta na lista!';
        msg.style.display = 'block';
        form.style.display = 'none';
      } else {
        msg.textContent = data.error || 'Algo deu errado.';
        msg.style.display = 'block';
        btn.disabled = false;
        btn.textContent = 'Entrar na lista';
      }
    } catch {
      msg.textContent = 'Algo deu errado.';
      msg.style.display = 'block';
      btn.disabled = false;
      btn.textContent = 'Entrar na lista';
    }
  });
</script>
