---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ProjectRoadmapStatus from '../../components/ProjectRoadmapStatus.astro';
import { ecosystemContent, projects } from '../../data/projects';
---

<DocsLayout title="Roadmap" description="Roadmap do ecossistema sens.legal." lang="pt-br">
  <h1>Roadmap</h1>

  <p>{ecosystemContent.roadmap.introPtBr}</p>

  <p>{ecosystemContent.roadmap.readingRulePtBr}</p>

  {projects.map((project) => (
    <>
      <h2>{project.name}</h2>
      <ProjectRoadmapStatus project={project} lang="pt-br" />
    </>
  ))}

  <h2>Ecossistema</h2>

  <ul>
    {ecosystemContent.roadmap.principlesPtBr.map((item) => (
      <li>{item}</li>
    ))}
  </ul>
</DocsLayout>
