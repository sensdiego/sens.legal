---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import ProjectRoadmapStatus from '../../../components/ProjectRoadmapStatus.astro';
import { projects } from '../../../data/projects';

const project = projects.find((item) => item.subdomain === 'juca');

if (!project) {
  throw new Error('Juca project data not found');
}
---

<DocsLayout title="Juca" description="Hub frontend para advogados no ecossistema sens.legal." lang="pt-br">
  <h1>Juca</h1>
  <p class="subtitle">Hub frontend para advogados</p>

  <span class="badge badge-dev">dev</span>

  <p>
    Juca e a interface pela qual profissionais do direito interagem com o
    ecossistema sens.legal. Ele organiza briefing, leitura, canvas e fluxos de
    trabalho para advogados brasileiros, servindo como hub frontend da experiencia.
  </p>

  <p>
    O backend juridico esta saindo do Juca e migrando para o Valter. Isso
    significa que busca, grafo, reasoning, verificacao e pipelines juridicos
    deixam de ser responsabilidade do frontend e passam a ser consumidos como
    servicos canonicos do backend do ecossistema.
  </p>

  <h2>Responsabilidades</h2>

  <ul>
    <li>Orquestrar a experiencia de briefing e argumentacao para usuarios finais</li>
    <li>Consumir Valter como backend de jurisprudencia, reasoning e verificacao</li>
    <li>Consumir Leci para grounding legislativo conforme a integracao amadurece</li>
    <li>Manter o foco em UX, estado de interface e fluxos de trabalho</li>
  </ul>

  <h2>Stack</h2>

  <ul>
    <li><strong>Framework:</strong> Next.js 15</li>
    <li><strong>Linguagem:</strong> TypeScript</li>
    <li><strong>UI:</strong> React, Tailwind CSS</li>
    <li><strong>Deploy:</strong> Vercel</li>
  </ul>

  <h2>Status do roadmap</h2>

  <ProjectRoadmapStatus project={project} lang="pt-br" />

  <h2>Links</h2>

  <ul>
    <li><a href="https://juca.sens.legal" target="_blank" rel="noopener">Documentacao</a></li>
    <li><a href="https://github.com/sensdiego/juca" target="_blank" rel="noopener">GitHub</a></li>
  </ul>
</DocsLayout>

<style>
  .subtitle {
    color: var(--color-text-muted);
    font-size: 1.125rem;
    margin-top: -0.5rem;
    margin-bottom: var(--space-md);
  }
</style>
