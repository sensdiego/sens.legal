---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ProjectRoadmapStatus from '../../components/ProjectRoadmapStatus.astro';
import { projects } from '../../data/projects';

const project = projects.find((item) => item.subdomain === 'juca');

if (!project) {
  throw new Error('Juca project data not found');
}
---

<DocsLayout title="Juca" description="Frontend hub for lawyers in the sens.legal ecosystem.">
  <h1>Juca</h1>
  <p class="subtitle">Frontend hub for lawyers</p>

  <span class="badge badge-dev">dev</span>

  <p>
    Juca is the interface through which legal professionals interact with the
    sens.legal ecosystem. It organizes briefing, reading, canvas, and workflow
    experiences for Brazilian lawyers, acting as the frontend hub of the product.
  </p>

  <p>
    That backend cutover is now complete. Search, graph logic, reasoning,
    verification, and legal chat pipelines are owned by Valter, while Juca
    operates as the shell-first frontend that consumes those canonical backend
    services.
  </p>

  <h2>Responsibilities</h2>

  <ul>
    <li>Orchestrate briefing and argument-building experiences for end users</li>
    <li>Consume Valter as the canonical backend for jurisprudence, reasoning, verification, and chat</li>
    <li>Consume Leci for legislative grounding as the integration matures</li>
    <li>Persist sessions and keep the focus on UX, interface state, and user workflows</li>
  </ul>

  <h2>Stack</h2>

  <ul>
    <li><strong>Framework:</strong> Next.js 16</li>
    <li><strong>Language:</strong> TypeScript</li>
    <li><strong>UI:</strong> React, Tailwind CSS</li>
    <li><strong>Deploy:</strong> Docker + Railway</li>
  </ul>

  <h2>Roadmap status</h2>

  <ProjectRoadmapStatus project={project} />

  <h2>Links</h2>

  <ul>
    <li><a href="https://juca.sens.legal" target="_blank" rel="noopener">Documentation</a></li>
  </ul>
</DocsLayout>

<style>
  .subtitle {
    color: var(--color-text-muted);
    font-size: 1.125rem;
    margin-top: -0.5rem;
    margin-bottom: var(--space-md);
  }
</style>
