---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ProjectRoadmapStatus from '../../components/ProjectRoadmapStatus.astro';
import { projects } from '../../data/projects';

const project = projects.find((item) => item.subdomain === 'leci');

if (!project) {
  throw new Error('Leci project data not found');
}
---

<DocsLayout title="Leci" description="Document-first legislation engine for reliable grounding in the sens.legal ecosystem.">
  <h1>Leci</h1>
  <p class="subtitle">Document-first legislation engine</p>

  <span class="badge badge-dev">dev</span>

  <p>
    Leci is the legislation engine of the sens.legal ecosystem. Its role is to
    provide reliable legislative grounding: resolving statutes, provisions, and
    document context through a <strong>document-first</strong> strategy instead of
    treating legislation as a vague extension of the jurisprudence backend.
  </p>

  <p>
    The project already has a working <code>/api/search</code>, a functional search
    and reading shell, typed contracts, and validation against live data. Leci's
    main consumers are Valter and Juca, which depend on it for current statutory
    text, ready-to-cite references, official sources, and structural context.
  </p>

  <h2>What is already operational</h2>

  <ul>
    <li><code>/api/search</code> running against PostgreSQL and live data</li>
    <li>Search and reading shell in the App Router to validate the document-first flow</li>
    <li>Search contract covered by tests and enriched regulation metadata</li>
    <li>Local workflow and Railway validation already documented</li>
  </ul>

  <h2>Stack</h2>

  <ul>
    <li><strong>Framework:</strong> Next.js App Router</li>
    <li><strong>Language:</strong> TypeScript</li>
    <li><strong>Database:</strong> PostgreSQL + pgvector</li>
    <li><strong>Infra:</strong> Railway</li>
  </ul>

  <h2>Roadmap status</h2>

  <ProjectRoadmapStatus project={project} />

  <h2>Links</h2>

  <ul>
    <li><a href="https://leci.sens.legal" target="_blank" rel="noopener">Documentation</a></li>
  </ul>
</DocsLayout>

<style>
  .subtitle {
    color: var(--color-text-muted);
    font-size: 1.125rem;
    margin-top: -0.5rem;
    margin-bottom: var(--space-md);
  }
</style>
