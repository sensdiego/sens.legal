---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ProjectRoadmapStatus from '../../components/ProjectRoadmapStatus.astro';
import { projects } from '../../data/projects';

const project = projects.find((item) => item.subdomain === 'valter');

if (!project) {
  throw new Error('Valter project data not found');
}
---

<DocsLayout title="Valter" description="Central jurisprudence and reasoning backend for the sens.legal ecosystem.">
  <h1>Valter</h1>
  <p class="subtitle">{project.description}</p>

  <span class="badge badge-dev">{project.status}</span>

  <div class="project-stack">
    {project.stack.map((tech) => (
      <code>{tech}</code>
    ))}
  </div>

  <ProjectRoadmapStatus project={project} />

  <p class="docs-link">
    <a href="https://valter.sens.legal" target="_blank" rel="noopener">
      Full documentation at valter.sens.legal &rarr;
    </a>
  </p>
</DocsLayout>

<style>
  .subtitle {
    color: var(--color-text-muted);
    font-size: 1rem;
    margin-top: -0.5rem;
    margin-bottom: var(--space-md);
    line-height: 1.5;
  }

  .project-stack {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-bottom: var(--space-lg);
  }

  .project-stack code {
    font-size: 0.75rem;
  }

  .docs-link {
    margin-top: var(--space-lg);
    font-size: 0.95rem;
  }
</style>
