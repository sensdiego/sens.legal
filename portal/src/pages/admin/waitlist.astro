---
export const prerender = false;

const token = Astro.url.searchParams.get('token');
const adminToken = process.env.ADMIN_TOKEN;

if (!adminToken || token !== adminToken) {
  return new Response('Unauthorized', { status: 401 });
}

import { supabase } from '../../lib/supabase';

const { data: entries } = await supabase.rpc('portal_waitlist_list');
const { data: count } = await supabase.rpc('portal_waitlist_count');
const total = count ?? 0;
const list = (entries ?? []) as Array<{ id: number; email: string; created_at: string; source: string }>;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Waitlist — sens.legal admin</title>
    <link rel="icon" type="image/png" href="/logo.png" />
  </head>
  <body>
    <header>
      <h1>Waitlist</h1>
      <span class="badge">{total} subscribers</span>
    </header>

    {list.length === 0 ? (
      <p class="empty">No entries yet.</p>
    ) : (
      <table>
        <thead>
          <tr>
            <th>#</th>
            <th>Email</th>
            <th>Source</th>
            <th>Date</th>
          </tr>
        </thead>
        <tbody>
          {list.map((entry, i) => (
            <tr>
              <td class="mono">{i + 1}</td>
              <td>{entry.email}</td>
              <td class="mono">{entry.source}</td>
              <td class="mono">{new Date(entry.created_at).toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' })}</td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </body>
</html>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: system-ui, "Helvetica Neue", Helvetica, Arial, sans-serif;
    background: #0f0f14;
    color: #e0e0e0;
    padding: 2rem;
    max-width: 60rem;
    margin: 0 auto;
  }

  header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid #2a2a2a;
  }

  h1 {
    font-size: 1.5rem;
    font-weight: 600;
    color: #ffffff;
  }

  .badge {
    background: #1a1a2e;
    color: #8b8bff;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 500;
  }

  .empty {
    color: #666;
    font-style: italic;
  }

  table {
    width: 100%;
    border-collapse: collapse;
  }

  th {
    text-align: left;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #888;
    padding: 0.5rem 1rem;
    border-bottom: 1px solid #2a2a2a;
  }

  td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid #1a1a1a;
    font-size: 0.9rem;
  }

  tr:hover td {
    background: #1a1a2e;
  }

  .mono {
    font-family: "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;
    font-size: 0.8rem;
    color: #999;
  }

  @media (max-width: 40rem) {
    body { padding: 1rem; }
    th, td { padding: 0.5rem; }
  }
</style>
