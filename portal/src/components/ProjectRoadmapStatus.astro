---
import type { Project } from '../data/projects';

interface Props {
  project: Project;
  lang?: 'en' | 'pt-br';
  compact?: boolean;
}

const { project, lang = 'en', compact = false } = Astro.props;
const isPtBr = lang === 'pt-br';
const roadmap = project.roadmap;
const progress = `${Math.round((roadmap.currentStage / roadmap.totalStages) * 100)}%`;
const blockers = isPtBr ? roadmap.blockersPtBr : roadmap.blockers;
const updates = roadmap.updates ?? [];
const labels = isPtBr
  ? {
      kicker: 'Posicao no roadmap',
      stage: 'Etapa',
      of: 'de',
      now: 'Agora',
      next: 'Proximo',
      blockers: 'Bloqueios e dependencias',
      stageMap: 'Mapa de etapas',
      updates: 'Ultimas atualizacoes',
      source:
        'Snapshot editorial derivado de progress, roadmap e, quando relevante, arquivos canonicos de migracao.',
    }
  : {
      kicker: 'Roadmap position',
      stage: 'Stage',
      of: 'of',
      now: 'Now',
      next: 'Next',
      blockers: 'Blockers and dependencies',
      stageMap: 'Stage map',
      updates: 'Latest updates',
      source:
        'Editorial snapshot derived from project progress, roadmap, and migration files when they add phase-specific context.',
    };
---

<section class:list={['roadmap-status', compact && 'compact']}>
  <div class="roadmap-header">
    <div>
      <p class="roadmap-kicker">{labels.kicker}</p>
      <p class="roadmap-position">
        {labels.stage} {roadmap.currentStage} {labels.of} {roadmap.totalStages}
      </p>
    </div>
    <p class="roadmap-current">
      {isPtBr ? roadmap.currentStageLabelPtBr : roadmap.currentStageLabel}
    </p>
  </div>

  <div
    class="roadmap-bar"
    role="img"
    aria-label={`${labels.stage} ${roadmap.currentStage} ${labels.of} ${roadmap.totalStages}`}
  >
    <span style={`width:${progress}`}></span>
  </div>

  <p class="roadmap-summary">{isPtBr ? roadmap.summaryPtBr : roadmap.summary}</p>

  <div class="roadmap-columns">
    <div class="roadmap-column">
      <p class="roadmap-micro">{labels.now}</p>
      <p>{isPtBr ? roadmap.nowPtBr : roadmap.now}</p>
    </div>
    <div class="roadmap-column">
      <p class="roadmap-micro">{labels.next}</p>
      <p>{isPtBr ? roadmap.nextPtBr : roadmap.next}</p>
    </div>
  </div>

  {!compact && blockers.length > 0 && (
    <div class="roadmap-section">
      <h3>{labels.blockers}</h3>
      <ul class="roadmap-list">
        {blockers.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </div>
  )}

  <div class="roadmap-section">
    <h3>{labels.stageMap}</h3>
    <div class="accordion-list">
      {roadmap.stages.map((stage, index) => {
        const stageNumber = index + 1;
        const stageState =
          stageNumber < roadmap.currentStage
            ? 'done'
            : stageNumber === roadmap.currentStage
              ? 'current'
              : 'upcoming';

        return (
          <details class:list={['accordion-item', `accordion-${stageState}`]}>
            <summary>
              <span class="stage-number">{stageNumber}</span>
              <span class="accordion-title">{isPtBr ? stage.titlePtBr : stage.title}</span>
            </summary>
            <p class="accordion-body">{isPtBr ? stage.descriptionPtBr : stage.description}</p>
          </details>
        );
      })}
    </div>
  </div>

  {updates.length > 0 && (
    <div class="roadmap-section">
      <h3>{labels.updates}</h3>
      <div class="accordion-list">
        {updates.map((update) => (
          <details class="accordion-item">
            <summary>
              <span class="update-date">{new Date(update.date + 'T00:00:00').toLocaleDateString(isPtBr ? 'pt-BR' : 'en-US', { day: '2-digit', month: 'short', year: 'numeric' })}</span>
              <span class="accordion-title">{isPtBr ? update.titlePtBr : update.title}</span>
            </summary>
            <p class="accordion-body">{isPtBr ? update.summaryPtBr : update.summary}</p>
          </details>
        ))}
      </div>
    </div>
  )}

  {!compact && (
    <p class="roadmap-source">{labels.source}</p>
  )}
</section>

<style>
  .roadmap-status {
    margin-top: var(--space-md);
    padding: 1.75rem;
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    background: rgba(148, 163, 184, 0.05);
  }

  .roadmap-status.compact {
    margin-top: var(--space-sm);
    padding: 1.25rem;
    border-radius: 0.5rem;
  }

  .roadmap-header {
    display: flex;
    justify-content: space-between;
    gap: var(--space-md);
    align-items: flex-start;
    margin-bottom: 0.75rem;
  }

  .roadmap-kicker,
  .roadmap-micro,
  .roadmap-source {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .roadmap-position,
  .roadmap-current {
    margin: 0.125rem 0 0;
    font-size: 0.95rem;
    font-weight: 600;
  }

  .roadmap-current {
    text-align: right;
  }

  .roadmap-bar {
    height: 0.55rem;
    border-radius: 9999px;
    background: rgba(148, 163, 184, 0.18);
    overflow: hidden;
  }

  .roadmap-bar span {
    display: block;
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, #111827 0%, #4b5563 100%);
  }

  .roadmap-summary {
    margin-top: 1rem;
    margin-bottom: 0;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .roadmap-columns {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
    margin-top: 1.25rem;
  }

  .roadmap-column p:last-child {
    margin-bottom: 0;
    line-height: 1.5;
  }

  .roadmap-section {
    margin-top: 1.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-border);
  }

  .roadmap-section h3 {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    margin: 0 0 0.75rem;
  }

  .roadmap-list {
    margin: 0;
    padding-left: 1.25rem;
  }

  .roadmap-list li {
    margin-bottom: 0.25rem;
    line-height: 1.5;
  }

  /* Shared accordion styles for stages and updates */

  .accordion-list {
    display: grid;
    gap: 0.375rem;
  }

  .accordion-item {
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    overflow: hidden;
    transition: border-color 0.15s ease;
  }

  .accordion-item[open] {
    border-color: rgba(148, 163, 184, 0.35);
  }

  .accordion-item summary {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.625rem 0.875rem;
    cursor: pointer;
    list-style: none;
    user-select: none;
    transition: background 0.15s ease;
  }

  .accordion-item summary::-webkit-details-marker {
    display: none;
  }

  .accordion-item summary::after {
    content: '\25B8';
    margin-left: auto;
    flex-shrink: 0;
    font-size: 0.65rem;
    color: var(--color-text-muted);
    transition: transform 0.15s ease;
  }

  .accordion-item[open] summary::after {
    transform: rotate(90deg);
  }

  .accordion-item summary:hover {
    background: rgba(148, 163, 184, 0.08);
  }

  .accordion-title {
    font-size: 0.85rem;
    font-weight: 500;
    line-height: 1.4;
  }

  .accordion-body {
    padding: 0 0.875rem 0.75rem 2.75rem;
    margin: 0;
    font-size: 0.825rem;
    color: var(--color-text-secondary);
    line-height: 1.55;
  }

  /* Stage-specific styles */

  .stage-number {
    width: 1.625rem;
    height: 1.625rem;
    border-radius: 9999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid currentColor;
    font-size: 0.75rem;
    flex-shrink: 0;
  }

  .accordion-done {
    color: var(--color-text);
  }

  .accordion-done summary {
    background: rgba(17, 24, 39, 0.04);
  }

  .accordion-current {
    color: var(--color-text);
    border-color: rgba(17, 24, 39, 0.25);
  }

  .accordion-current summary {
    background: rgba(17, 24, 39, 0.08);
  }

  .accordion-upcoming {
    color: var(--color-text-secondary);
  }

  /* Update-specific styles */

  .update-date {
    font-family: var(--font-mono, 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace);
    font-size: 0.7rem;
    color: var(--color-text-muted);
    flex-shrink: 0;
    min-width: 5.25rem;
  }

  .roadmap-source {
    margin-top: 1.5rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
    text-transform: none;
    letter-spacing: 0;
    font-size: 0.8rem;
  }

  @media (max-width: 42rem) {
    .roadmap-status {
      padding: 1.25rem;
    }

    .roadmap-header,
    .roadmap-columns {
      grid-template-columns: 1fr;
      display: grid;
    }

    .roadmap-current {
      text-align: left;
    }

    .update-date {
      min-width: auto;
    }

    .accordion-body {
      padding-left: 0.875rem;
    }
  }
</style>
